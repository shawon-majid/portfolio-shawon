OPENAI_API_KEY=

# OPENAI_MODEL and ASK_RATE_LIMIT_MAX below are seed defaults only.
# At runtime the admin panel (/admin) overrides them via the settings blob.
# The rate-limit window is fixed at 1 hour (per IP) by the server action.
OPENAI_MODEL=gpt-4o-mini
ASK_RATE_LIMIT_MAX=10

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Required so the admin panel can persist settings + KB uploads to Vercel Blob.
BLOB_READ_WRITE_TOKEN=

ADMIN_USER=admin
ADMIN_PASS=admin
